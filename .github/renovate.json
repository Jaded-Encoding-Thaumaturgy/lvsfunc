{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "semanticCommits": "enabled",
  "schedule": [
    "* 14 * * 1,4"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "pep621"
      ],
      "groupName": "Python dependencies"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    }
  ]
}
